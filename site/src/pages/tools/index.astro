---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Free BluePainter Tools — Contrast & Receipt Graders"
  description="Free top-of-funnel tools: WCAG contrast checker, Designer's Receipts grader, and TSX id analyzer. Unlock full reports with email."
>
  <section class="section">
    <p class="eyebrow">Free tools</p>
    <h1>Instant value. Path to the demo.</h1>
    <p class="lead">Lightweight graders powered by the same receipt logic as BluePainter. Email unlocks a full report and a direct link into the live studio.</p>
    <div class="grid-3" style="margin-top:32px">
      <a class="card" href="/tools/contrast-checker" style="color:inherit">
        <span class="badge">A11y</span>
        <h3>Contrast checker</h3>
        <p class="muted">WCAG contrast on button backgrounds — same engine as Designer's Receipts.</p>
      </a>
      <a class="card" href="/tools/receipt-grader" style="color:inherit">
        <span class="badge">Policy</span>
        <h3>Receipt grader</h3>
        <p class="muted">Score spacing, contrast, CTA copy, radius, and clutter in one pass.</p>
      </a>
      <a class="card" href="/tools/tsx-id-analyzer" style="color:inherit">
        <span class="badge">Sync</span>
        <h3>TSX id analyzer</h3>
        <p class="muted">Count syncable JSX id attributes for BluePainter canvas mapping.</p>
      </a>
    </div>
  </section>
</BaseLayout>
