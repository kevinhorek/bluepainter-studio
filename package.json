{
  "name": "bluepainter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "vercel dev",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy:vercel": "npm run build && npx vercel --prod",
    "deploy:netlify": "npm run build && npx netlify deploy --prod --dir=dist",
    "site:dev": "npm --prefix site run dev",
    "site:build": "npm --prefix site run build",
    "site:guides": "node scripts/generate-guides.mjs",
    "mcp:start": "npm --prefix mcp start",
    "repurpose": "node scripts/repurpose.mjs"
  },
  "dependencies": {
    "@babel/parser": "^8.0.0",
    "@babel/traverse": "^8.0.0",
    "@babel/types": "^8.0.0",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recast": "^0.23.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.6",
    "vite": "^8.0.12"
  }
}
